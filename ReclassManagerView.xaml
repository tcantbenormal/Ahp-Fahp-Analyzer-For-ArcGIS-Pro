<Window x:Class="AhpFahpAnalyzer.ReclassManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AhpFahpAnalyzer"
        mc:Ignorable="d"
        Title="Reclassification Manager" Height="560" Width="800" 
        WindowStartupLocation="CenterScreen" Background="#F5F6F8">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#ADADAD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <TextBlock Text="Rasters Pending Reclassification" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" Grid.Column="0" Grid.Row="0"/>
        <TextBlock Text="Raster Break Properties" FontWeight="SemiBold" FontSize="14" Margin="15,0,0,10" Grid.Column="1" Grid.Row="0"/>
        
        <ListBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Rasters}" SelectedItem="{Binding SelectedRaster}" DisplayMemberPath="RasterName" Margin="0,0,10,0" 
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
        
        <Border Grid.Row="1" Grid.Column="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="5,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Raster Statistics Info Panel -->
                    <Border Background="#E8F4FD" BorderBrush="#B3D9F2" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Raster Minimum" FontSize="11" Foreground="#555"/>
                                <TextBlock Text="{Binding SelectedRaster.RasterMin, StringFormat='{}{0:F4}'}" FontWeight="Bold" FontSize="14" Foreground="#0066CC"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Raster Maximum" FontSize="11" Foreground="#555"/>
                                <TextBlock Text="{Binding SelectedRaster.RasterMax, StringFormat='{}{0:F4}'}" FontWeight="Bold" FontSize="14" Foreground="#0066CC"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                <TextBlock Text="Status" FontSize="11" Foreground="#555"/>
                                <TextBlock Text="{Binding SelectedRaster.StatsStatusText}" FontSize="11" Foreground="#333" TextWrapping="Wrap" MaxWidth="150"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Reclassification Method and Controls -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Method:" VerticalAlignment="Center" Width="60" FontWeight="SemiBold"/>
                        <ComboBox Grid.Column="1" Grid.Row="0" ItemsSource="{Binding ReclassMethods}" 
                                  SelectedItem="{Binding SelectedRaster.ReclassMethod}" 
                                  Width="160" Height="25" Padding="5,2" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Column="2" Grid.Row="0" Text="Classes:" VerticalAlignment="Center" Margin="15,0,5,0" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="3" Grid.Row="0" 
                                 Text="{Binding SelectedRaster.NumberOfClasses, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="50" Height="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                        <!-- Defined Interval Width (greyed out unless 'Defined Interval' is selected) -->
                        <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Interval Width:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"
                                       IsEnabled="{Binding SelectedRaster.IsDefinedInterval}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedRaster.IsDefinedInterval}" Value="False">
                                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding SelectedRaster.DefinedIntervalWidth, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="70" Height="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                     IsEnabled="{Binding SelectedRaster.IsDefinedInterval}"/>
                            <Button Content="🔄 Regenerate Intervals" Command="{Binding RegenerateIntervalsCommand}" 
                                    Margin="20,0,0,0" Padding="10,3" Background="#E8F0FE" BorderBrush="#4285F4" Foreground="#1A73E8" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                
                    <TextBlock Text="Interval Matrix Definition (Lower Bound → Upper Bound → Reclassified Score)" Margin="0,0,0,8" Foreground="#505050"/>
                
                    <DataGrid ItemsSource="{Binding SelectedRaster.Intervals}" AutoGenerateColumns="False" CanUserAddRows="False" 
                              CanUserDeleteRows="False" MinHeight="180" MaxHeight="280" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Minimum Value" Binding="{Binding MinVal, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F4}'}" Width="*" />
                            <DataGridTextColumn Header="Maximum Value" Binding="{Binding MaxVal, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:F4}'}" Width="*" />
                            <DataGridTextColumn Header="Converted Score" Binding="{Binding NewVal}" Width="110" IsReadOnly="True">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#707070" Margin="0,12,0,0">
                        <Run FontWeight="SemiBold">💡 Tips:</Run><LineBreak/>
                        • Select a raster from the left panel to auto-load its min/max statistics.<LineBreak/>
                        • Choose a method and click "Regenerate Intervals" to recompute breakpoints.<LineBreak/>
                        • For "Manual Interval", breakpoints are pre-filled but fully editable.<LineBreak/>
                        • For "Defined Interval", set the desired Interval Width before regenerating.
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- Bottom Action Bar / Output directory -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,15,0,0" Padding="10" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Output Path:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" Height="26" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseOutputDirectoryCommand}" Width="80" Height="26" Margin="0,0,15,0"/>
                <Button Grid.Column="3" Content="Done &amp; Close" Width="100" Height="26" Background="#0066CC" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Click="CloseButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
